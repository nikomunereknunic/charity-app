# Zkopírujte tento soubor jako ".env" a vyplňte vlastní hodnoty.
# .env se NIKDY nesmí nahrávat do gitu ani sdílet, obsahuje API klíč k vaší peněžence.

# Základní URL vaší LNbits instance (bez koncového lomítka)
LNBITS_API_URL=https://legend.lnbits.com/api/v1

# Invoice key z LNbits (Wallet -> API info -> Invoice/read key)
LNBITS_API_KEY=vlozte_svuj_invoice_klic_sem

# Port, na kterém poběží server
PORT=3000
